# =========================================================================
# WebVault Production Environment Configuration Example
# Copy this file to '.env' and modify the values before deployment.
# =========================================================================

# Secure JSON Web Token (JWT) secret key (Use a strong cryptographically random 64-char string)
# openssl rand -hex 64
JWT_SECRET=your-secure-jwt-signature-key-change-me-in-production

# Default administrator username (Avoid standard 'admin' username in public production)
APP_USER=admin

# Default administrator salted bcrypt password hash
# Generate your custom password hash on your host using a bcrypt CLI.
# Note: $ characters in bcrypt hashes must be written as $$ inside the .env file
# to escape Docker Compose's variable interpolation.
# The default hash below corresponds to the password "admin":
APP_PASSWORD_HASH=$$2b$$10$$Omeni.3WNo8vvgfkNI44hOFFdCGX8Aw3R3ExsKULC09.7oLmTEyF.

# Node Server Configuration
PORT=8080
NODE_ENV=production
